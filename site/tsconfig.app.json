{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Resolve the workspace library straight from its TS source.
       Without baseUrl (deprecated in TS 6), paths resolve relative to this file. */
    "paths": {
      "wplot": ["../src/lib/index.ts"],
      "wplot/extensions": ["../src/plugins/index.ts"]
    },

    /* Type checking */
    "strict": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
